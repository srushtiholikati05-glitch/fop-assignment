/*Write a menu driven program in C to implement the basic arithmetic operations such as Addition, Subtraction, Multiplication, 
and Division*/
#include<stdio.h>

int main(){
    int a,b;
    printf("ENter the number :");
    scanf("%d,%d",&a,&b);
    int n;
    float c = a/b;
    printf("ENter the number of operation u want (max 4):");
    scanf("%d",&n);
    if(n==0){
        printf("THere is no operation\n");
    } else if(n==1){
        printf("Addition of two numbers %d\n",a+b);
    }else if(n==2){
        printf("Addition of two numbers %d\n",a+b);
        printf("Subtraction of two numbers %d\n",a-b);
    }else if(n==3){
        printf("Addition of two numbers %d\n",a+b);
        printf("Subtraction of two numbers %d\n",a-b);
        printf("Multipication of two numbers %d\n",a*b);        
    }else if(n==4){
        printf("Addition of two numbers %d\n",a+b);
        printf("Subtraction of two numbers %d\n",a-b);
        printf("Multipication of two numbers is %d\n",a*b);
        printf("Division of two numbers is %.2f",c);
    }
    return 0;
}
