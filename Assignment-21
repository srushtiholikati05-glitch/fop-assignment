
#include<stdio.h>
int main(){
    FILE *fp;
    char str[1100],st[100];
    printf("ENter the name of file:");
    scanf("%s",st);

    fp=fopen(st,"w");
    printf("Enter the lines (to stop enter END):");
    while(1){
        fgets(str,sizeof(str),stdin);
        if(str[0]=='E' && str[1]=='N' && str[2]=='D'){
            break;
        }
        fputc(str,fp);
    }
    fclose(fp);
    fp=fopen(st,"r");
    printf("\n dstination file destination.text will contain:\n ");
    while(fgetc(str,sizeof(str),fp)!=NULL ){
        printf("%s",str);
    }
    fclose(fp);
    return 0;
}
